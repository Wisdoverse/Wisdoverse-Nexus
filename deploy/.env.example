# =============================================================
# Wisdoverse Nexus Docker Compose 环境变量模板
# 复制为 .env 后修改为实际值：cp .env.example .env
# =============================================================

# --- 运行环境 ---
NEXIS_ENV=development
RUST_LOG=nexis=debug

# --- JWT ---
NEXIS_JWT_SECRET=dev-secret-change-me
NEXIS_JWT_ISSUER=https://auth.example.internal
NEXIS_JWT_AUDIENCE=nexis

# --- 数据库 ---
POSTGRES_DB=nexis
POSTGRES_USER=nexis
POSTGRES_PASSWORD=nexis
NEXIS_DATABASE_URL=postgres://nexis:nexis@postgres:5432/nexis
NEXIS_DATABASE_POOL_SIZE=20

# --- Redis ---
NEXIS_REDIS_URL=redis://redis:6379/0

# --- 可观测性 ---
GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
