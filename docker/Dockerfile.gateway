# Multi-stage build: Stage 1 - Compile
FROM rust:1.95-slim AS builder

RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy Cargo files (leverage Docker cache)
COPY Cargo.toml Cargo.lock ./
COPY crates ./crates

# Build nexis-gateway in release mode
RUN cargo build --release -p nexis-gateway

# Stage 2 - Runtime
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
    ca-certificates \
    libssl3 \
    && rm -rf /var/lib/apt/lists/* \
    && useradd -r -s /bin/false nexis

WORKDIR /app

COPY --from=builder /app/target/release/nexis-gateway /usr/local/bin/nexis-gateway

RUN mkdir -p /app/data && chown nexis:nexis /app/data

USER nexis

EXPOSE 8080

ENV RUST_LOG=info
ENV NEXIS_DEFAULT_PROVIDER=mock
ENV NEXIS_DATABASE_PATH=/app/data/nexis.db

CMD ["nexis-gateway"]
