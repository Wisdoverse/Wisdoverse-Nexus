  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "parameters": {
      "ApiVersion": {
        "name": "x-api-version",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string",
          "enum": [
            "1"
          ]
        }
      },
      "RoomId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "CollaborationRoomId": {
        "name": "room_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "DocumentId": {
        "name": "document_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "TaskId": {
        "name": "task_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Validation or request contract error"
      },
      "Unauthorized": {
        "description": "Missing or invalid authorization token"
      },
      "NotFound": {
        "description": "Resource not found"
      },
      "RateLimited": {
        "description": "Rate limit exceeded"
      },
      "ServiceUnavailable": {
        "description": "Dependent service unavailable"
      }
    }
